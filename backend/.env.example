# ─────────────────────────────────────────────────────────────
# BACKEND environment variables  (TEMPLATE — no real secrets here)
# ─────────────────────────────────────────────────────────────
# On Render: set these under  Service → Environment.
# Locally:   copy to `backend/.env` (git-ignored) and fill in real values,
#            or just leave API_SECRET empty to disable auth for dev.
# ─────────────────────────────────────────────────────────────

# Shared secret the frontend must send in the `X-API-Key` header.
# Must match VITE_API_KEY in the frontend. Generate: openssl rand -hex 32
# No quotes. Leave empty for local dev.
API_SECRET=your-secret-here

# Allowed frontend origin for CORS. Your Netlify URL, NO trailing slash.
# Leave empty for local dev (allows all).
ALLOWED_ORIGIN=https://your-site.netlify.app

# Where converted files are written before cleanup. Usually leave as-is.
OUTPUT_DIR=/tmp/audtube

# Path to a YouTube cookies.txt (Netscape format) from a logged-in session.
# REQUIRED on Render — YouTube blocks datacenter IPs without it.
# On Render: add cookies.txt as a Secret File, then set this to its path,
#   e.g. /etc/secrets/cookies.txt
# Leave empty for local dev (your home IP usually works without cookies).
YOUTUBE_COOKIES_FILE=/etc/secrets/cookies.txt
